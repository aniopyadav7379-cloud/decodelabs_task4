# Server
PORT=5000
NODE_ENV=development

# CORS — the exact origin(s) allowed to call this API from the browser.
# In production, list your deployed frontend URL(s), comma-separated.
CORS_ORIGIN=http://localhost:5500,http://127.0.0.1:5500

# Auth — protects create/update/delete/bulk-delete. Reads stay public.
# Change these before deploying anywhere real.
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRES_IN=8h
ADMIN_USERNAME=admin
ADMIN_PASSWORD=ChangeMe123!

# Pagination default (can be overridden per-request with ?limit=)
DEFAULT_PAGE_SIZE=9
